    details{margin-top:16px;border:1px solid var(--line);border-radius:13px;background:var(--panel2);padding:12px 14px}summary{cursor:pointer;font-weight:750}.formula-list{display:grid;gap:7px;margin-top:12px;color:var(--muted);font-size:13px}.formula{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;color:#cbe7ff}.note{margin-top:13px;padding:10px 12px;border-left:3px solid var(--yellow);background:#2c2817;color:#f6e7ad;font-size:12px}.story{margin-top:16px;background:#0b1726;border:1px solid var(--line);border-radius:14px;padding:15px;color:#d7e7f7}.footer{color:var(--muted);font-size:11px;margin-top:15px;text-align:center}
    @media(max-width:880px){.hero{display:block}.actions{justify-content:flex-start;margin-top:15px}.layout{grid-template-columns:1fr}.metrics{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:520px){.wrap{padding:18px 11px 35px}.field{grid-template-columns:1fr}.field input{text-align:left}.metrics{grid-template-columns:1fr}.index{grid-template-columns:1fr}}
    @media print{body{background:white;color:#111}.wrap{max-width:none;padding:0}.hero,.layout{display:block}.actions,.status{display:none}.card,.metric,.index,.story,details{background:white;color:#111;box-shadow:none;border-color:#bbb;margin-bottom:12px}.lead,.sub,.help,.metric-name,.metric-unit,.formula-list{color:#444}input{border:0;background:white;color:#111}.badge{background:white}.footer{color:#444}}
  </style>
  <style>
    :root{--bg:#eef3f8;--panel:#ffffff;--panel2:#f6f8fb;--text:#213044;--muted:#66758a;--line:#dbe3ec;--cyan:#1677c8;--blue:#2764b5;--green:#2f9e67;--yellow:#e9a23b;--red:#d14b55;--input:#eaf8ef}
    body{background:linear-gradient(145deg,#f9fbfd 0,#eaf1f8 48%,#f4f7fa 100%);color:var(--text)}
    .hero{background:linear-gradient(135deg,#ffffff 0,#edf6ff 100%);border:1px solid #d7e4f1;border-radius:22px;padding:24px;box-shadow:0 16px 40px rgba(42,75,110,.09)}
    .eyebrow{color:#1769aa}.lead,.sub,.help,.metric-name,.metric-unit,.index-label,.footer{color:var(--muted)}
    button{background:linear-gradient(135deg,#1684d6,#245da9);color:white;box-shadow:0 5px 14px rgba(35,102,169,.2)}button.secondary{background:white;color:#36516d;border-color:#cbd7e4;box-shadow:none}
    .card{background:white;border-color:#dbe4ed;box-shadow:0 14px 35px rgba(47,72,99,.08)}
    .field{background:linear-gradient(90deg,#f5fcf7,#edf9f1);border-color:#cbe8d5}.field:hover{border-color:#78bd93}.field label{color:#244335}
    input,select{background:white;color:#173025;border:1.5px solid #86c69e;box-shadow:inset 0 1px 2px rgba(20,80,45,.05)}select{text-align:left;cursor:pointer}input.invalid,select.invalid{background:#fff1f2;color:#512229}
    .index{background:linear-gradient(135deg,#edf6ff,#f7fbff);border-color:#bfd7ed}.index-value{color:#165f9f}
