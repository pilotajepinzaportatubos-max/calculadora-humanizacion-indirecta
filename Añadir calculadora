    button{border:0;border-radius:10px;padding:11px 15px;font-weight:750;cursor:pointer;background:linear-gradient(135deg,var(--cyan),var(--blue));color:#06101c}button.secondary{background:#17283a;color:var(--text);border:1px solid var(--line)}button:focus-visible,input:focus-visible{outline:3px solid rgba(52,214,232,.38);outline-offset:2px}
    .layout{display:grid;grid-template-columns:minmax(320px,.85fr) minmax(420px,1.15fr);gap:16px}.card{background:linear-gradient(180deg,rgba(255,255,255,.025),transparent),var(--panel);border:1px solid var(--line);border-radius:17px;padding:19px;box-shadow:0 18px 50px rgba(0,0,0,.2)}h2{font-size:18px;margin:0 0 4px}.sub{color:var(--muted);font-size:13px;margin-bottom:16px}
    .fields{display:grid;gap:11px}.field{display:grid;grid-template-columns:minmax(0,1fr) 150px;align-items:center;gap:12px;padding:10px 12px;border:1px solid #294335;border-radius:12px;background:rgba(23,54,35,.38)}label{font-weight:650}.help{display:block;color:var(--muted);font-size:11px;font-weight:400;margin-top:2px}input,select{width:100%;border:1px solid #3e7352;border-radius:9px;background:var(--input);color:#fff;padding:10px 11px;font-size:16px;text-align:right;font-variant-numeric:tabular-nums}input.invalid,select.invalid{border-color:var(--red);background:#351c24}.status{min-height:22px;margin-top:12px;color:var(--muted);font-size:13px}.status.error{color:#ffb1b1}.status.ok{color:#91efb5}
